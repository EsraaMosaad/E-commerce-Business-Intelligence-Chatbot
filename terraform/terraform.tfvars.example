# ─────────────────────────────────────────────────────────────────────────────
# Group 25fltp — E-commerce BI Chatbot
# ─────────────────────────────────────────────────────────────────────────────

aws_region        = "us-east-1"
environment      = "dev"
instance_type    = "t3.large"
ami_id           = "ami-0c55b159cbfafe1f0"  # Ubuntu 22.04 LTS in us-east-1
vpc_cidr         = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"

# ⚠️ CHANGE THIS to your actual IP address (find at: https://whatismyip.com)
# Format: "203.0.113.42/32" (must include /32)
allowed_ip        = "0.0.0.0/0"

# Group 25fltp — S3 bucket and key
s3_bucket_name   = "25fltp-ecom-chatbot"
key_name         = "25fltp-ecom-key"
ollama_model_path = "model/tinyllama-chat.Q4_K_M.gguf"

# ─────────────────────────────────────────────────────────────────────────────
# EMR Configuration (Data Preprocessing)
# ─────────────────────────────────────────────────────────────────────────────
emr_master_instance_type  = "m6i.2xlarge"
emr_core_instance_type    = "m6i.2xlarge"
emr_core_instance_count   = 2  # 1 master + 2 core nodes
